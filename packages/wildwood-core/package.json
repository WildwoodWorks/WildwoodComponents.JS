{
  "name": "@wildwood/core",
  "version": "0.1.0",
  "description": "Wildwood API core SDK - authentication, API client, and services for browser and Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "msw": "^2.12.10",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@microsoft/signalr": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@microsoft/signalr": {
      "optional": true
    }
  },
  "keywords": [
    "wildwood",
    "sdk",
    "api-client",
    "authentication",
    "jwt",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wildwood-platform/wildwood-js.git",
    "directory": "packages/wildwood-core"
  },
  "homepage": "https://github.com/wildwood-platform/wildwood-js/tree/master/packages/wildwood-core#readme",
  "bugs": {
    "url": "https://github.com/wildwood-platform/wildwood-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
