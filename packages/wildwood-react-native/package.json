{
  "name": "@wildwood/react-native",
  "version": "0.1.0",
  "description": "Wildwood React Native SDK - Native components and hooks",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@wildwood/core": "workspace:*",
    "@wildwood/react-shared": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@wildwood/core": "workspace:*",
    "@wildwood/react-shared": "workspace:*",
    "@types/react": "^19.1.0",
    "@types/react-native": "^0.73.0",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "wildwood",
    "react-native",
    "hooks",
    "components",
    "mobile",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wildwood-platform/wildwood-js.git",
    "directory": "packages/wildwood-react-native"
  },
  "homepage": "https://github.com/wildwood-platform/wildwood-js/tree/master/packages/wildwood-react-native#readme",
  "bugs": {
    "url": "https://github.com/wildwood-platform/wildwood-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
