{
  "name": "@wildwood/react",
  "version": "0.1.0",
  "description": "Wildwood React components, hooks, and provider for WildwoodAPI integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/wildwood-themes.css",
    "./dist/wildwood-themes.css": "./dist/wildwood-themes.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "storybook": "^10.2.15",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@wildwood/core": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "keywords": [
    "wildwood",
    "react",
    "hooks",
    "components",
    "authentication",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wildwood-platform/wildwood-js.git",
    "directory": "packages/wildwood-react"
  },
  "homepage": "https://github.com/wildwood-platform/wildwood-js/tree/master/packages/wildwood-react#readme",
  "bugs": {
    "url": "https://github.com/wildwood-platform/wildwood-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
