{
  "name": "@wildwood/react",
  "version": "0.1.0",
  "description": "Wildwood React components, hooks, and provider for WildwoodAPI integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/wildwood-themes.css",
    "./dist/wildwood-themes.css": "./dist/wildwood-themes.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@wildwood/core": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "license": "MIT"
}
