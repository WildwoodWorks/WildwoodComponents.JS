{
  "name": "@wildwood/react-shared",
  "version": "0.1.0",
  "description": "Shared React hooks for Wildwood SDK - used by @wildwood/react and @wildwood/react-native",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@wildwood/core": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@wildwood/core": "workspace:*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
