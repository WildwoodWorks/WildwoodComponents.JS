{
  "name": "@wildwood/node",
  "version": "0.1.0",
  "description": "Wildwood Node.js SDK - Express middleware and server-side utilities",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@wildwood/core": "workspace:*",
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.5",
    "@wildwood/core": "workspace:*",
    "express": "^5.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "wildwood",
    "node",
    "express",
    "middleware",
    "jwt",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wildwood-platform/wildwood-js.git",
    "directory": "packages/wildwood-node"
  },
  "homepage": "https://github.com/wildwood-platform/wildwood-js/tree/master/packages/wildwood-node#readme",
  "bugs": {
    "url": "https://github.com/wildwood-platform/wildwood-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
