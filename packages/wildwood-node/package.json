{
  "name": "@wildwood/node",
  "version": "0.1.0",
  "description": "Wildwood Node.js SDK - Express middleware and server-side utilities",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@wildwood/core": "workspace:*"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@wildwood/core": "workspace:*",
    "@types/express": "^5.0.0",
    "express": "^5.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
