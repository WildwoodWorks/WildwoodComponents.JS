{
  "name": "wildwood-js",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/wildwood-core/src/**/*.{ts,tsx}": [
      "pnpm --filter @wildwood/core run lint"
    ],
    "packages/wildwood-react/src/**/*.{ts,tsx}": [
      "pnpm --filter @wildwood/react run lint"
    ],
    "packages/wildwood-react-native/src/**/*.{ts,tsx}": [
      "pnpm --filter @wildwood/react-native run lint"
    ],
    "packages/wildwood-node/src/**/*.{ts,tsx}": [
      "pnpm --filter @wildwood/node run lint"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2"
  }
}
